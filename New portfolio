<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Hemanshi Gajra — Data Analyst</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Syne+Mono&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --c0:#fdf9f4;--c1:#f5ede0;--c2:#ecdcc8;
  --acc:#d4622a;--acc2:#e8875a;--acc3:#f2a97f;
  --deep:#8c3a14;--ink:#1a130d;--sub:#5c4435;--faint:#a08070;
  --glow:rgba(212,98,42,.22);--glass:rgba(255,252,248,.6);--r:20px;
}
html{scroll-behavior:smooth}
body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--c0);color:var(--ink);cursor:none;overflow-x:hidden;line-height:1.6}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:var(--c1)}::-webkit-scrollbar-thumb{background:var(--acc);border-radius:4px}

/* CURSOR */
#cur-dot{width:8px;height:8px;background:var(--acc);border-radius:50%;position:fixed;top:0;left:0;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:width .15s,height .15s,background .2s;mix-blend-mode:multiply}
#cur-ring{width:40px;height:40px;border:1.5px solid var(--acc);border-radius:50%;position:fixed;top:0;left:0;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:width .3s,height .3s,border-color .3s,opacity .3s;opacity:.5}
body.hov #cur-ring{width:64px;height:64px;opacity:1;border-color:var(--deep)}
body.hov #cur-dot{width:5px;height:5px;background:var(--deep)}
body.click #cur-dot{width:14px;height:14px}

/* CANVAS */
#bg-canvas{position:fixed;inset:0;pointer-events:none;z-index:0;opacity:.65}

/* NOISE */
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");opacity:.025;pointer-events:none;z-index:0}

/* NAV */
nav{position:fixed;top:0;width:100%;z-index:200;padding:0 5%;height:70px;display:flex;align-items:center;justify-content:space-between;transition:background .4s,box-shadow .4s}
nav.scrolled{background:rgba(253,249,244,.9);backdrop-filter:blur(20px);box-shadow:0 1px 0 rgba(212,98,42,.12),0 8px 40px rgba(60,20,5,.07)}
.nav-logo{font-family:'Playfair Display',serif;font-size:1.35rem;font-weight:900;color:var(--acc);text-decoration:none;letter-spacing:-.5px}
.nav-links{display:flex;gap:36px;list-style:none}
.nav-links a{font-size:.78rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--sub);text-decoration:none;position:relative;transition:color .2s}
.nav-links a::before{content:'';position:absolute;bottom:-4px;left:50%;right:50%;height:1.5px;background:var(--acc);transition:left .3s,right .3s}
.nav-links a:hover{color:var(--acc)}
.nav-links a:hover::before{left:0;right:0}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:none;border:none;background:none;padding:4px}
.hamburger span{display:block;height:2px;width:26px;background:var(--acc);border-radius:2px;transition:all .3s}

/* HERO */
#hero{min-height:100vh;display:flex;align-items:center;padding:100px 5% 60px;position:relative;z-index:1;overflow:hidden}
.hero-deco{position:absolute;right:-2%;top:50%;transform:translateY(-50%);font-family:'Playfair Display',serif;font-size:clamp(16rem,28vw,30rem);font-weight:900;font-style:italic;color:transparent;-webkit-text-stroke:1.5px rgba(212,98,42,.08);line-height:1;pointer-events:none;user-select:none;animation:letterFloat 8s ease-in-out infinite}
@keyframes letterFloat{0%,100%{transform:translateY(-50%) rotate(-3deg)}50%{transform:translateY(-52%) rotate(-2deg)}}
.hero-inner{max-width:1100px;margin:0 auto;width:100%;display:grid;grid-template-columns:1.15fr 1fr;gap:60px;align-items:center}

.hero-tag{display:inline-flex;align-items:center;gap:10px;background:rgba(212,98,42,.08);border:1px solid rgba(212,98,42,.2);border-radius:50px;padding:7px 18px;font-size:.75rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--acc);margin-bottom:28px;opacity:0;animation:slideR .7s .1s forwards}
.hero-tag .blink{width:7px;height:7px;border-radius:50%;background:var(--acc);animation:blink 1.5s infinite;flex-shrink:0}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.hero-name{font-family:'Playfair Display',serif;font-size:clamp(3.2rem,6.5vw,5.8rem);font-weight:900;line-height:.95;letter-spacing:-3px;color:var(--ink);opacity:0;animation:slideR .8s .25s forwards}
.hero-name .italic-name{font-style:italic;color:var(--acc);display:block}
.hero-type-wrap{margin:22px 0;font-size:1rem;color:var(--sub);display:flex;align-items:center;gap:8px;opacity:0;animation:slideR .8s .4s forwards}
.type-prefix{font-weight:300;color:var(--faint)}
#typewriter{font-family:'Syne Mono',monospace;color:var(--acc)}
.type-cur{display:inline-block;width:2px;height:1em;background:var(--acc);animation:blink .8s infinite;vertical-align:middle;margin-left:2px}
.hero-desc{font-size:.95rem;color:var(--sub);line-height:1.85;max-width:440px;font-weight:300;margin-bottom:36px;opacity:0;animation:slideR .8s .55s forwards}
.hero-ctas{display:flex;gap:14px;flex-wrap:wrap;opacity:0;animation:slideR .8s .7s forwards}
.btn-mag{position:relative;overflow:hidden;padding:15px 36px;border-radius:50px;font-family:'Plus Jakarta Sans',sans-serif;font-size:.86rem;font-weight:600;letter-spacing:.04em;cursor:none;text-decoration:none;display:inline-flex;align-items:center;gap:8px;transition:transform .3s,box-shadow .3s}
.btn-fill{background:linear-gradient(135deg,var(--acc),var(--acc2));color:#fff;box-shadow:0 6px 28px rgba(212,98,42,.38),inset 0 1px 0 rgba(255,255,255,.2)}
.btn-fill:hover{box-shadow:0 10px 40px rgba(212,98,42,.5)}
.btn-ghost{border:1.5px solid var(--acc);color:var(--acc);background:transparent}
.btn-ghost:hover{background:rgba(212,98,42,.06)}

/* Scroll indicator */
.scroll-ind{position:absolute;bottom:36px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;opacity:0;animation:fadeIn 1s 1.2s forwards;z-index:2}
.scroll-ind span{font-size:.68rem;letter-spacing:.15em;text-transform:uppercase;color:var(--faint);font-weight:500}
.scroll-mouse{width:24px;height:38px;border:2px solid rgba(212,98,42,.35);border-radius:12px;display:flex;justify-content:center;padding-top:6px}
.scroll-wheel{width:3px;height:8px;background:var(--acc);border-radius:3px;animation:scrollD 1.8s ease-in-out infinite}
@keyframes scrollD{0%{transform:translateY(0);opacity:1}80%{transform:translateY(10px);opacity:0}100%{transform:translateY(0);opacity:0}}

/* Hero right */
.hero-right{position:relative;opacity:0;animation:fadeIn .9s .8s forwards}
.photo-wrap{position:relative;width:100%;aspect-ratio:4/5;max-width:360px;margin:0 auto}
.photo-bg{position:absolute;inset:0;background:linear-gradient(145deg,var(--c2),var(--c1));border-radius:60% 40% 55% 45%/50% 60% 40% 50%;animation:morph 10s ease-in-out infinite}
@keyframes morph{0%,100%{border-radius:60% 40% 55% 45%/50% 60% 40% 50%}33%{border-radius:50% 50% 45% 55%/40% 60% 40% 60%}66%{border-radius:40% 60% 60% 40%/60% 40% 60% 40%}}
.photo-initials{position:absolute;inset:20px;background:linear-gradient(145deg,var(--acc),var(--acc2),#f2c49c);display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:clamp(4rem,10vw,7rem);font-weight:900;font-style:italic;color:rgba(255,255,255,.95);border-radius:55% 45% 50% 50%/45% 55% 45% 55%;animation:morph 10s 2s ease-in-out infinite;box-shadow:0 30px 80px rgba(212,98,42,.35);letter-spacing:-4px}
.fcard{position:absolute;background:var(--glass);backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,.85);border-radius:16px;padding:14px 18px;box-shadow:0 8px 32px rgba(60,20,5,.12);display:flex;align-items:center;gap:12px;white-space:nowrap;z-index:3}
.fi{font-size:1.4rem}
.finfo{display:flex;flex-direction:column}
.fval{font-family:'Syne Mono',monospace;font-size:.95rem;font-weight:700;color:var(--acc);line-height:1}
.flbl{font-size:.68rem;color:var(--faint);font-weight:500;text-transform:uppercase;letter-spacing:.08em;margin-top:2px}
.fc1{top:-20px;left:-30px;animation:floatA 5s ease-in-out infinite}
.fc2{bottom:30px;right:-25px;animation:floatB 6s ease-in-out infinite}
.fc3{top:45%;left:-40px;animation:floatA 7s 1s ease-in-out infinite}
@keyframes floatA{0%,100%{transform:translateY(0) rotate(-1deg)}50%{transform:translateY(-10px) rotate(1deg)}}
@keyframes floatB{0%,100%{transform:translateY(0) rotate(1deg)}50%{transform:translateY(-12px) rotate(-1deg)}}
.orb{position:absolute;border-radius:50%;filter:blur(60px);pointer-events:none;opacity:.5}
.orb1{width:300px;height:300px;background:rgba(212,98,42,.15);top:-80px;right:-60px;animation:drift 12s ease-in-out infinite alternate}
.orb2{width:200px;height:200px;background:rgba(242,169,127,.2);bottom:-40px;left:-30px;animation:drift 9s ease-in-out infinite alternate-reverse}
@keyframes drift{from{transform:translate(0,0)}to{transform:translate(20px,25px)}}

/* MARQUEE */
.marquee-wrap{position:relative;z-index:1;background:var(--acc);padding:14px 0;overflow:hidden;border-top:1px solid var(--deep);border-bottom:1px solid var(--deep)}
.marquee-inner{display:flex;gap:0;animation:marquee 25s linear infinite;width:max-content}
.marquee-inner span{font-family:'Playfair Display',serif;font-size:.95rem;font-style:italic;color:rgba(255,255,255,.9);padding:0 32px;white-space:nowrap}
.marquee-inner .sep{color:rgba(255,255,255,.4);font-style:normal;padding:0}
@keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* SECTIONS */
section{position:relative;z-index:1}
.container{max-width:1100px;margin:0 auto;padding:0 5%}
.sec-pad{padding:110px 5%}
.sec-eye{display:inline-flex;align-items:center;gap:10px;font-size:.72rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--acc);margin-bottom:14px}
.sec-eye::before{content:'';width:28px;height:1.5px;background:var(--acc)}
.sec-title{font-family:'Playfair Display',serif;font-size:clamp(2.2rem,4.5vw,3.6rem);font-weight:900;line-height:1.05;letter-spacing:-1.5px;color:var(--ink);margin-bottom:16px}
.sec-title em{font-style:italic;color:var(--acc)}
.sec-sub{font-size:.95rem;color:var(--sub);font-weight:300;line-height:1.8;max-width:520px;margin-bottom:50px}

/* Reveal */
.rev{opacity:0;transform:translateY(36px);transition:opacity .75s,transform .75s}
.rev.vis{opacity:1;transform:translateY(0)}
.rev-l{opacity:0;transform:translateX(-36px);transition:opacity .75s,transform .75s}
.rev-l.vis{opacity:1;transform:translateX(0)}
.rev-r{opacity:0;transform:translateX(36px);transition:opacity .75s,transform .75s}
.rev-r.vis{opacity:1;transform:translateX(0)}
.d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}.d4{transition-delay:.4s}

/* ABOUT */
#about{background:var(--c0)}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;margin-top:20px}
.about-img-col{position:relative}
.about-img-bg{width:100%;aspect-ratio:1;background:linear-gradient(145deg,var(--c2),var(--c1));border-radius:40% 60% 55% 45%/50% 45% 55% 50%;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;animation:morph 12s ease-in-out infinite}
.about-big{font-family:'Playfair Display',serif;font-size:clamp(6rem,14vw,11rem);font-weight:900;font-style:italic;color:rgba(212,98,42,.18);user-select:none;letter-spacing:-6px}
.about-stat{position:absolute;background:var(--glass);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,.85);border-radius:14px;padding:16px 20px;box-shadow:0 8px 30px rgba(60,20,5,.1);text-align:center}
.as1{bottom:-20px;left:-20px}.as2{top:20px;right:-20px}
.stat-num{font-family:'Playfair Display',serif;font-size:2rem;font-weight:900;color:var(--acc);line-height:1}
.stat-lbl{font-size:.72rem;color:var(--faint);text-transform:uppercase;letter-spacing:.08em;font-weight:500;margin-top:3px}
.about-text h3{font-family:'Playfair Display',serif;font-size:1.8rem;font-weight:700;font-style:italic;color:var(--ink);margin-bottom:20px;line-height:1.25}
.about-text p{font-size:.93rem;color:var(--sub);line-height:1.9;font-weight:300;margin-bottom:16px}
.about-text strong{color:var(--acc);font-weight:600}
.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:28px}
.dg-item{display:flex;align-items:center;gap:10px;background:rgba(212,98,42,.05);border:1px solid rgba(212,98,42,.12);border-radius:12px;padding:12px 16px}
.dg-item span{font-size:.83rem;font-weight:500;color:var(--sub)}

/* SKILLS */
#skills{background:var(--c1)}
.skills-layout{display:grid;grid-template-columns:1fr 1.6fr;gap:80px;align-items:start}
.skills-left p{font-size:.93rem;color:var(--sub);line-height:1.85;font-weight:300;margin-bottom:28px}
.soft-badges{display:flex;flex-wrap:wrap;gap:10px;margin-top:24px}
.soft-badge{padding:8px 18px;border-radius:50px;font-size:.78rem;font-weight:600;border:1.5px solid rgba(212,98,42,.25);color:var(--acc);background:rgba(212,98,42,.06);transition:all .2s;cursor:none}
.soft-badge:hover{background:var(--acc);color:#fff}
.hex-grid{display:flex;flex-wrap:wrap;gap:16px}
.skill-hex{background:var(--glass);backdrop-filter:blur(14px);border:1px solid rgba(255,255,255,.85);border-radius:var(--r);padding:24px 22px;flex:1 1 160px;box-shadow:0 4px 20px rgba(60,20,5,.06);transition:transform .3s,box-shadow .3s;position:relative;overflow:hidden;cursor:none}
.skill-hex::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,transparent 60%,rgba(212,98,42,.06));opacity:0;transition:opacity .3s}
.skill-hex:hover{transform:translateY(-8px) scale(1.02);box-shadow:0 16px 48px rgba(212,98,42,.18)}
.skill-hex:hover::after{opacity:1}
.sh-emoji{font-size:1.8rem;margin-bottom:10px;display:block}
.sh-name{font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:var(--ink);margin-bottom:10px}
.sh-bar{height:3px;background:var(--c2);border-radius:10px;overflow:hidden;margin-bottom:6px}
.sh-fill{height:100%;background:linear-gradient(90deg,var(--acc),var(--acc3));border-radius:10px;width:0;transition:width 1.2s ease}
.sh-pct{font-size:.72rem;color:var(--faint);font-weight:500}

/* PROJECTS */
#projects{background:var(--c0)}
.projects-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:50px;flex-wrap:wrap;gap:20px}
.projects-header .sec-sub{margin-bottom:0}
.projects-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.project-card{background:var(--glass);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,.85);border-radius:24px;padding:34px;box-shadow:0 4px 24px rgba(60,20,5,.07);display:flex;flex-direction:column;gap:18px;position:relative;overflow:hidden;transition:transform .35s,box-shadow .35s;cursor:none}
.project-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--acc),var(--acc3),transparent);transform:scaleX(0);transform-origin:left;transition:transform .5s}
.project-card:hover{transform:translateY(-10px);box-shadow:0 24px 64px rgba(212,98,42,.2)}
.project-card:hover::before{transform:scaleX(1)}
.project-card.featured{grid-column:span 2}
.pc-num{font-family:'Playfair Display',serif;font-size:4rem;font-weight:900;font-style:italic;color:rgba(212,98,42,.1);line-height:1;position:absolute;top:20px;right:24px}
.pc-tag{display:inline-flex;align-items:center;gap:6px;background:rgba(212,98,42,.1);border-radius:50px;padding:5px 14px;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--acc);width:fit-content}
.pc-title{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;color:var(--ink);line-height:1.25}
.project-card.featured .pc-title{font-size:1.5rem}
.pc-desc{font-size:.86rem;color:var(--sub);line-height:1.8;font-weight:300}
.pc-tools{display:flex;flex-wrap:wrap;gap:8px}
.pc-tool{background:rgba(255,255,255,.7);border:1px solid var(--c2);border-radius:50px;padding:4px 12px;font-size:.73rem;color:var(--faint);font-weight:500}
.pc-footer{display:flex;align-items:center;justify-content:space-between;margin-top:auto}
.pc-link{font-size:.82rem;font-weight:600;color:var(--acc);text-decoration:none;display:flex;align-items:center;gap:6px;transition:gap .25s}
.pc-link:hover{gap:12px}
.pc-arrow{width:36px;height:36px;border-radius:50%;border:1.5px solid rgba(212,98,42,.3);display:flex;align-items:center;justify-content:center;font-size:1rem;transition:background .2s,border-color .2s}
.project-card:hover .pc-arrow{background:var(--acc);border-color:var(--acc);color:#fff}

/* EDUCATION */
#education{background:var(--c1)}
.edu-layout{display:grid;grid-template-columns:1fr 1.2fr;gap:80px;align-items:start}
.edu-timeline{position:relative;padding-left:40px}
.edu-timeline::before{content:'';position:absolute;left:10px;top:0;bottom:0;width:2px;background:linear-gradient(to bottom,var(--acc),rgba(212,98,42,.1))}
.edu-item{position:relative;margin-bottom:48px;opacity:0;transform:translateX(-20px);transition:opacity .7s,transform .7s}
.edu-item.vis{opacity:1;transform:translateX(0)}
.edu-item::before{content:'';position:absolute;left:-36px;top:6px;width:14px;height:14px;border-radius:50%;background:var(--acc);box-shadow:0 0 0 4px rgba(212,98,42,.15)}
.edu-year{font-family:'Syne Mono',monospace;font-size:.75rem;color:var(--acc);font-weight:700;letter-spacing:.08em;margin-bottom:8px}
.edu-card{background:var(--glass);backdrop-filter:blur(14px);border:1px solid rgba(255,255,255,.85);border-radius:18px;padding:24px 28px;box-shadow:0 4px 20px rgba(60,20,5,.07);transition:transform .3s,box-shadow .3s}
.edu-card:hover{transform:translateX(6px);box-shadow:0 8px 32px rgba(212,98,42,.15)}
.edu-card h3{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;color:var(--ink);margin-bottom:4px}
.edu-inst{font-size:.83rem;color:var(--faint);margin-bottom:14px}
.sem-wrap{display:flex;flex-wrap:wrap;gap:8px}
.sem-chip{background:rgba(212,98,42,.08);border:1px solid rgba(212,98,42,.2);border-radius:50px;padding:4px 12px;font-size:.73rem;font-weight:600;color:var(--acc);font-family:'Syne Mono',monospace}
.sem-chip.best{background:var(--acc);color:#fff;border-color:var(--acc)}
.edu-chart-col h3{font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:700;color:var(--ink);margin-bottom:6px}
.edu-chart-col p{font-size:.88rem;color:var(--sub);font-weight:300;margin-bottom:28px;line-height:1.7}
.cgpa-row{display:flex;align-items:center;gap:14px;margin-bottom:16px}
.cgpa-label{font-family:'Syne Mono',monospace;font-size:.78rem;color:var(--faint);width:52px;flex-shrink:0;font-weight:600}
.cgpa-track{flex:1;height:8px;background:var(--c2);border-radius:10px;overflow:hidden}
.cgpa-fill{height:100%;background:linear-gradient(90deg,var(--acc),var(--acc3));border-radius:10px;width:0;transition:width 1.3s ease}
.cgpa-val{font-family:'Syne Mono',monospace;font-size:.82rem;font-weight:700;color:var(--acc);width:36px;text-align:right;flex-shrink:0}
.career-obj{margin-top:32px;background:linear-gradient(135deg,rgba(212,98,42,.08),rgba(232,135,90,.05));border:1px solid rgba(212,98,42,.18);border-radius:18px;padding:24px}
.career-obj-lbl{font-size:.78rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:var(--acc);margin-bottom:10px}
.career-obj-text{font-size:.9rem;color:var(--sub);line-height:1.8;font-weight:300;font-style:italic}

/* CONTACT */
#contact{background:var(--c0)}
.contact-layout{display:grid;grid-template-columns:1fr 1.1fr;gap:80px;align-items:start}
.contact-left h3{font-family:'Playfair Display',serif;font-size:1.6rem;font-weight:700;font-style:italic;color:var(--ink);margin-bottom:16px;line-height:1.3}
.contact-left p{font-size:.93rem;color:var(--sub);line-height:1.85;font-weight:300;margin-bottom:34px}
.contact-cards{display:flex;flex-direction:column;gap:14px}
.cc{display:flex;align-items:center;gap:16px;background:var(--glass);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.85);border-radius:16px;padding:16px 20px;text-decoration:none;color:var(--ink);box-shadow:0 4px 16px rgba(60,20,5,.06);transition:transform .3s,box-shadow .3s,border-color .3s}
